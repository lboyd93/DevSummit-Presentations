# ArcGIS OAuth 2.0 application credentials
CLIENT_ID=YOUR_CLIENT_ID
CLIENT_SECRET=YOUR_CLIENT_SECRET

# Optional metadata used in token cache
ARCGIS_USER_ID=

# Required for session handling
SESSION_SECRET=change-me-to-a-long-random-string
ENCRYPTION_KEY=change-me-to-a-long-random-string

# Optional: enable HTTPS by pointing at your local TLS key/cert files
# SSL_KEY_PATH=/absolute/or/relative/path/to/server.key
# SSL_CERT_PATH=/absolute/or/relative/path/to/server.crt

# Optional: change the listening port
# PORT=3080
